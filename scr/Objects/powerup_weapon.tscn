[gd_scene load_steps=3 format=3 uid="uid://cwm0fs724515w"]  # Это заголовок сцены. Он включает информацию о загрузке, формате сцены и уникальном идентификаторе.

# Начало узла "Weapon", который будет представлять оружие. Используем узел типа Area2D, так как это 2D объект, который может взаимодействовать с другими объектами (например, столкновения).
[node name="Weapon" type="Area2D"]
position = Vector2(100, 100)  # Устанавливаем позицию оружия в игровом мире. Оно будет расположено в точке (100, 100).

# Создание дочернего узла Sprite2D для отображения изображения оружия.
# "parent = '.'" означает, что этот узел будет дочерним по отношению к узлу "Weapon" (родительский узел).
[node name="Sprite2D" type="Sprite2D" parent="."]  
texture = preload("res://assets/weapon_placeholder.png")  # Загрузка текстуры для отображения оружия. Текстура загружается из указанного пути. (Используется "preload" для предзагрузки ресурса на старте игры).

# Создание коллизий для оружия. Используем узел CollisionShape2D для определения области столкновения.
[node name="CollisionShape2D" type="CollisionShape2D" parent="."]  
shape = RectangleShape2D.new()  # Создаём прямоугольную форму для коллизий.
shape.extents = Vector2(16, 16)  # Устанавливаем размеры коллизионной области. В данном случае, 16x16 пикселей.
